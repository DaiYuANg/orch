// Full-stack docker provider example using the short .orch DSL.
//
// Topology:
// - frontend: public HTTP UI
// - backend: HTTP API
// - postgres: database
// - redis: cache / queue
//
// Before deploying locally, create the Docker network used by every workload:
//
//   docker network create orch-demo
//
// Replace the frontend/backend image names with images you build and publish.
// The app-level docker block is inherited by every shorthand workload below.

app {
  name = "fullstack"
  namespace = "demo"

  docker {
    network = "orch-demo"
  }

  stateful postgres {
    image = "postgres:16-alpine"
    env = {
      POSTGRES_DB = "app",
      POSTGRES_USER = "orch",
      POSTGRES_PASSWORD = "orch-dev-password",
    }

    tcp(5432)
    resources = "500m/512Mi"
  }

  stateful redis {
    image = "redis:7-alpine"
    command = ["redis-server"]
    args = ["--appendonly", "yes"]

    tcp(6379)
    resources = "250m/256Mi"
  }

  service backend {
    image = "ghcr.io/acme/fullstack-backend:latest"
    depends_on = [postgres, redis]
    env = {
      DATABASE_URL = "postgres://orch:orch-dev-password@orch-demo-postgres:5432/app?sslmode=disable",
      REDIS_ADDR = "orch-demo-redis:6379",
      HTTP_ADDR = ":8080",
    }

    http(8080)
    resources = "500m/512Mi"
  }

  service frontend {
    image = "ghcr.io/acme/fullstack-frontend:latest"
    depends_on = [backend]
    env = {
      API_BASE_URL = "/api",
    }

    http(80)
    resources = "250m/256Mi"
  }

  ingress public {
    path "/api" {
      workload = backend
    }

    path "/" {
      workload = frontend
    }
  }
}
